name = "rss-trigger-build"
main = "rss-trigger-build.js"
compatibility_date = "2023-10-30"

# KVネームスペースの設定
kv_namespaces = [
  { binding = "RSS_MONITOR", id = {YOUR_KV_NAMESPACE_ID} }
]

# 以下はsecretとして設定してください
# wrangler secret put DEPLOY_HOOK_URL
# wrangler secret put MANUAL_TRIGGER_TOKEN

# スケジュール設定（毎週金曜日の午前9時に実行）
[triggers]
crons = ["0 9 * * 5"]
